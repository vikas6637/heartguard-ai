# HeartGuard AI — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your actual values

# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/heartguard

# JWT (use a strong random secret, 64+ characters)
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET_64_CHARS_MINIMUM
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (adjust for production)
FRONTEND_URL=http://localhost:5173

# ML Microservice
ML_SERVICE_URL=http://localhost:8000

# Gemini API (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Razorpay (get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET
