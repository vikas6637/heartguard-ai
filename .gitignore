# ═══════════════════════════════════════════
#  HeartGuard AI — .gitignore
# ═══════════════════════════════════════════

# ── Environment & Secrets ──
.env
.env.*
!.env.example
*.pem
*.key

# ── Dependencies ──
node_modules/
venv/
.venv/
__pycache__/
*.pyc

# ── Build output ──
dist/
build/
*.egg-info/

# ── IDE / OS ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Internal docs (not for public) ──
START_ALL.md
frontend/README.md

# ── ML model artifacts (large) ──
*.h5
*.pt
*.onnx
*.joblib
!ml_service/model/

# ── Coverage & Testing ──
coverage/
.nyc_output/
htmlcov/
.pytest_cache/

# ── Misc ──
.gemini/
*.tgz
*.tar.gz
*.zip
